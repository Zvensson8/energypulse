{
  "name": "energypulse",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node scripts/smoke-fas1.mjs && node scripts/smoke-fas2.mjs && node scripts/smoke-fas3.mjs",
    "gen:types": "npx supabase gen types typescript --project-id jbnttxywunvvvivdfzeh > lib/supabase/database.types.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:api": "playwright test e2e/tests/data-gap.spec.ts e2e/tests/override-audit.spec.ts e2e/tests/rls-property-manager.spec.ts e2e/tests/security-tenant.spec.ts --project=chromium",
    "perf:seed": "node --env-file=.env.local scripts/perf/seed-portfolio.mjs",
    "perf:dashboard": "node --env-file=.env.local scripts/perf/bench-dashboard.mjs",
    "perf:import": "node --env-file=.env.local scripts/perf/bench-import.mjs",
    "perf:all": "npm run perf:import && npm run perf:dashboard",
    "seed:pilot": "node --env-file=.env.local scripts/seed-pilot.mjs"
  },
